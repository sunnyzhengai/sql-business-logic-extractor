      ]
    },
    {
      "name": "HSP_ACCOUNT_ID",
      "type": "passthrough",
      "resolved_expression": "HSP_ACCOUNT.HSP_ACCOUNT_ID",
      "direct_expression": "a.HSP_ACCOUNT_ID",
      "base_columns": [
        "HSP_ACCOUNT.HSP_ACCOUNT_ID"
      ],
      "base_tables": [
        "HSP_ACCOUNT"
      ],
      "filters": [
        "NOT a.DISCH_DATE_TIME IS NULL"
      ]
    },
    {
      "name": "admission_date",
      "type": "passthrough",
      "resolved_expression": "HSP_ACCOUNT.ADM_DATE_TIME",
      "direct_expression": "a.ADM_DATE_TIME AS admission_date",
      "base_columns": [
        "HSP_ACCOUNT.ADM_DATE_TIME"
      ],
      "base_tables": [
        "HSP_ACCOUNT"
      ],
      "filters": [
