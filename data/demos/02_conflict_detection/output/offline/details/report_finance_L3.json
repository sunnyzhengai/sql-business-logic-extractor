{
  "columns": [
    {
      "name": "PAT_ID",
      "type": "passthrough",
      "resolved_expression": "PATIENT.PAT_ID",
      "direct_expression": "p.PAT_ID",
      "base_columns": [
        "PATIENT.PAT_ID"
      ],
      "base_tables": [
        "PATIENT"
      ],
      "filters": [
        "NOT h.HOSP_DISCH_TIME IS NULL",
        "DATEDIFF(DAY, h.HOSP_ADMSN_TIME, HOSP_DISCH_TIME) > 0 /* Exclude same-day */"
      ]
    },
    {
