        ],
        "transformation_chain": []
      },
      "english_definition": "Categorization with 1 condition(s) (filtered by: NOT h.HOSP_DISCH_TIME IS NULL; filtered by: DATEDIFF(DAY, h.HOSP_ADMSN_TIME, HOSP_DISCH_TIME) > 0 /* Exclude same-day */)",
      "business_domain": "Quality Metrics"
    },
    {
      "column_name": "patient_age",
      "column_type": "calculated",
      "technical_definition": {
        "resolved_expression": "DATEDIFF(YEAR, p.BIRTH_DATE, HOSP_ADMSN_TIME)",
        "base_columns": [
