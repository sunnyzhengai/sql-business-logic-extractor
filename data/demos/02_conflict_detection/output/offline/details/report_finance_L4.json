          "DATEDIFF(DAY, h.HOSP_ADMSN_TIME, HOSP_DISCH_TIME) > 0 /* Exclude same-day */"
        ],
        "transformation_chain": []
      },
      "english_definition": "Age in years (at Hospital Admission Time) (filtered by: NOT h.HOSP_DISCH_TIME IS NULL; filtered by: DATEDIFF(DAY, h.HOSP_ADMSN_TIME, HOSP_DISCH_TIME) > 0 /* Exclude same-day */)",
      "business_domain": "Patient Demographics"
    }
