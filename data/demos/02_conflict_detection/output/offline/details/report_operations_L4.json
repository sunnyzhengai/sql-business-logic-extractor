      "column_type": "case",
      "technical_definition": {
        "resolved_expression": "CASE WHEN EXISTS(SELECT 1 FROM PAT_ENC AS e2 WHERE e2.PAT_ID = e.PAT_ID AND e2.APPT_TIME > e.CONTACT_DATE AND DATEDIFF(DAY, e.CONTACT_DATE, APPT_TIME) <= 7) THEN 1 ELSE 0 END /* Readmission: Within 7 days (not 30!) using encounter dates */",
        "base_columns": [
