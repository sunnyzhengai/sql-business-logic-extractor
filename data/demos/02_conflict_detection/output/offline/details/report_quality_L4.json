      "column_name": "length_of_stay",
      "column_type": "calculated",
      "technical_definition": {
        "resolved_expression": "DATEDIFF(DAY, a.ADM_DATE_TIME, DISCH_DATE_TIME) + 1",
        "base_columns": [
          "HSP_ACCOUNT.DAY",
          "HSP_ACCOUNT.ADM_DATE_TIME"
        ],
        "base_tables": [
          "HSP_ACCOUNT"
        ],
        "filters": [
          "NOT a.DISCH_DATE_TIME IS NULL"
        ],
        "transformation_chain": []
      },
      "english_definition": "Number of days between Admission Date Time and Discharge Date Time (plus 1) (filtered by: NOT a.DISCH_DATE_TIME IS NULL)",
      "business_domain": "Hospital Metrics"
    },
    {
      "column_name": "readmission_flag",
      "column_type": "case",
      "technical_definition": {
        "resolved_expression": "CASE WHEN EXISTS(SELECT 1 FROM HSP_ACCOUNT AS a2 WHERE a2.PAT_ID = a.PAT_ID AND a2.ADM_DATE_TIME > a.ADM_DATE_TIME AND DATEDIFF(DAY, a.ADM_DATE_TIME, ADM_DATE_TIME) <= 30) THEN 1 ELSE 0 END /* Readmission: Within 30 days of ADMISSION (not discharge!) */",
        "base_columns": [
          "HSP_ACCOUNT.PAT_ID",
          "HSP_ACCOUNT.ADM_DATE_TIME",
          "HSP_ACCOUNT.DAY"
        ],
        "base_tables": [
          "HSP_ACCOUNT"
        ],
        "filters": [
          "NOT a.DISCH_DATE_TIME IS NULL"
        ],
        "transformation_chain": []
      },
      "english_definition": "Categorization with 1 condition(s) (filtered by: NOT a.DISCH_DATE_TIME IS NULL)",
      "business_domain": "Quality Metrics"
    },
    {
      "column_name": "patient_age",
      "column_type": "calculated",
      "technical_definition": {
        "resolved_expression": "DATEDIFF(YEAR, p.BIRTH_DATE, DISCH_DATE_TIME)",
        "base_columns": [
          "HSP_ACCOUNT.YEAR",
          "PATIENT.BIRTH_DATE"
        ],
        "base_tables": [
          "HSP_ACCOUNT",
          "PATIENT"
        ],
        "filters": [
          "NOT a.DISCH_DATE_TIME IS NULL"
        ],
        "transformation_chain": []
      },
      "english_definition": "Age in years (at Discharge Date Time) (filtered by: NOT a.DISCH_DATE_TIME IS NULL)",
      "business_domain": "Patient Demographics"
    }
