{
  "summary": {
    "query_summary": "The query retrieves patient details and hospital account information for patients who have been discharged. It includes patient identifiers, admission and discharge dates, length of stay, readmission status within 30 days, and patient age at discharge.",
    "primary_purpose": "To analyze patient discharge patterns and readmission risks.",
    "key_entities": [
      "patients",
      "hospital accounts"
    ],
    "key_metrics": [
      "length_of_stay",
      "readmission_flag",
      "patient_age"
    ],
    "source_tables": [
      "HSP_ACCOUNT",
      "PATIENT"
    ],
    "business_domains": [
      "Clinical Risk",
      "Patient Demographics"
    ],
    "column_count": 8
  },
  "columns": [
    {
      "column_name": "PAT_ID",
      "column_type": "passthrough",
      "technical_definition": {
        "resolved_expression": "PATIENT.PAT_ID",
        "base_columns": [
          "PATIENT.PAT_ID"
        ],
        "base_tables": [
          "PATIENT"
        ],
        "filters": [
          "NOT a.DISCH_DATE_TIME IS NULL"
        ],
        "transformation_chain": []
      },
      "english_definition": "Unique identifier for a patient.",
      "business_domain": "Patient Demographics"
    },
    {
      "column_name": "PAT_NAME",
      "column_type": "passthrough",
      "technical_definition": {
        "resolved_expression": "PATIENT.PAT_NAME",
        "base_columns": [
          "PATIENT.PAT_NAME"
        ],
        "base_tables": [
          "PATIENT"
        ],
        "filters": [
          "NOT a.DISCH_DATE_TIME IS NULL"
        ],
        "transformation_chain": []
      },
      "english_definition": "Full name of the patient.",
      "business_domain": "Patient Demographics"
    },
    {
      "column_name": "HSP_ACCOUNT_ID",
      "column_type": "passthrough",
      "technical_definition": {
        "resolved_expression": "HSP_ACCOUNT.HSP_ACCOUNT_ID",
        "base_columns": [
          "HSP_ACCOUNT.HSP_ACCOUNT_ID"
        ],
        "base_tables": [
          "HSP_ACCOUNT"
        ],
        "filters": [
          "NOT a.DISCH_DATE_TIME IS NULL"
        ],
        "transformation_chain": []
      },
      "english_definition": "Unique identifier for a hospital account where discharge date and time is not null.",
      "business_domain": "Patient Demographics"
    },
    {
      "column_name": "admission_date",
      "column_type": "passthrough",
      "technical_definition": {
        "resolved_expression": "HSP_ACCOUNT.ADM_DATE_TIME",
        "base_columns": [
          "HSP_ACCOUNT.ADM_DATE_TIME"
        ],
        "base_tables": [
          "HSP_ACCOUNT"
        ],
        "filters": [
          "NOT a.DISCH_DATE_TIME IS NULL"
        ],
        "transformation_chain": []
      },
      "english_definition": "The date and time when a patient was admitted to the hospital, excluding records without a discharge date.",
      "business_domain": "Patient Demographics"
    },
    {
      "column_name": "discharge_date",
      "column_type": "passthrough",
      "technical_definition": {
        "resolved_expression": "HSP_ACCOUNT.DISCH_DATE_TIME",
        "base_columns": [
          "HSP_ACCOUNT.DISCH_DATE_TIME"
        ],
        "base_tables": [
          "HSP_ACCOUNT"
        ],
        "filters": [
          "NOT a.DISCH_DATE_TIME IS NULL"
        ],
        "transformation_chain": []
      },
      "english_definition": "The discharge date and time for a hospital account, excluding null values.",
      "business_domain": "Patient Demographics"
    },
    {
      "column_name": "length_of_stay",
      "column_type": "calculated",
      "technical_definition": {
        "resolved_expression": "DATEDIFF(DAY, a.ADM_DATE_TIME, DISCH_DATE_TIME) + 1",
        "base_columns": [
          "HSP_ACCOUNT.DAY",
          "HSP_ACCOUNT.ADM_DATE_TIME"
        ],
        "base_tables": [
          "HSP_ACCOUNT"
        ],
        "filters": [
          "NOT a.DISCH_DATE_TIME IS NULL"
        ],
        "transformation_chain": []
      },
      "english_definition": "Number of days from admission to discharge, inclusive of both dates.",
      "business_domain": "Patient Demographics"
    },
    {
      "column_name": "readmission_flag",
      "column_type": "case",
      "technical_definition": {
        "resolved_expression": "CASE WHEN EXISTS(SELECT 1 FROM HSP_ACCOUNT AS a2 WHERE a2.PAT_ID = a.PAT_ID AND a2.ADM_DATE_TIME > a.ADM_DATE_TIME AND DATEDIFF(DAY, a.ADM_DATE_TIME, ADM_DATE_TIME) <= 30) THEN 1 ELSE 0 END /* Readmission: Within 30 days of ADMISSION (not discharge!) */",
        "base_columns": [
          "HSP_ACCOUNT.PAT_ID",
          "HSP_ACCOUNT.ADM_DATE_TIME",
          "HSP_ACCOUNT.DAY"
        ],
        "base_tables": [
          "HSP_ACCOUNT"
        ],
        "filters": [
          "NOT a.DISCH_DATE_TIME IS NULL"
        ],
        "transformation_chain": []
      },
      "english_definition": "1 if the patient has another admission within 30 days after the current admission date, otherwise 0.",
      "business_domain": "Clinical Risk"
    },
    {
      "column_name": "patient_age",
      "column_type": "calculated",
      "technical_definition": {
        "resolved_expression": "DATEDIFF(YEAR, p.BIRTH_DATE, DISCH_DATE_TIME)",
        "base_columns": [
          "HSP_ACCOUNT.YEAR",
          "PATIENT.BIRTH_DATE"
        ],
        "base_tables": [
          "HSP_ACCOUNT",
          "PATIENT"
        ],
        "filters": [
          "NOT a.DISCH_DATE_TIME IS NULL"
        ],
        "transformation_chain": []
      },
      "english_definition": "The number of years between the patient's birth date and their discharge date.",
      "business_domain": "Patient Demographics"
    }
  ]
}