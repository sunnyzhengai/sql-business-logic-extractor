            {
              "expression": "EXISTS(SELECT 1 FROM Clarity.dbo.REFERRAL_HIST AS RFLH WHERE RFLH.REFERRAL_ID = RFL.Referralid AND RFLH.NEW_RFL_STATUS_C = 5 /* Denied */ UNION ALL SELECT 1 FROM Clarity.dbo.REFERRAL_BED_DAY AS RFLBD WHERE RFL.Referralid = RFLBD.REFERRAL_ID AND RFLBD.BED_DAY_STATUS_C = 2 /* Denied */)",
              "english": "there exists a row where either (from REFERRAL_HIST, where New Rfl Status C = 5) or (from REFERRAL_BED_DAY, where Bed Day Status C = 2)",
              "kind": "where"
            }
