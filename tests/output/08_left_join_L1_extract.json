  "raw_sql": "SELECT e.PAT_ENC_CSN_ID, dx.DX_NAME\n        
  FROM PAT_ENC_HSP e\n        
  LEFT JOIN HSP_ACCT_DX_LIST dl ON e.HSP_ACCOUNT_ID = dl.HSP_ACCOUNT_ID\n        
