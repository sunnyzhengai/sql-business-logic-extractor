  "raw_sql": "
  SELECT dept_stats.DEPARTMENT_NAME, dept_stats.avg_los, dept_stats.encounter_count\n        
  FROM 
  (\n         SELECT dep.DEPARTMENT_NAME,\n                   
              AVG(DATEDIFF(DAY, e.HOSP_ADMSN_TIME, e.HOSP_DISCH_TIME)) AS avg_los,\n                   
              COUNT(*) AS encounter_count\n            
              FROM PAT_ENC_HSP e\n            
              JOIN CLARITY_DEP dep ON e.DEPARTMENT_ID = dep.DEPARTMENT_ID\n            
              WHERE e.HOSP_DISCH_TIME IS NOT NULL\n            
              GROUP BY dep.DEPARTMENT_NAME\n        
              ) dept_stats 
  WHERE dept_stats.avg_los > 5"
