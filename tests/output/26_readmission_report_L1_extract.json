    {
      "name": "flagged",
      "query": "SELECT wr.*, CASE WHEN wr.days_to_readmit <= 30 THEN 1 ELSE 0 END AS is_30day_readmit, CASE WHEN wr.days_to_readmit <= 7 THEN 'Early' WHEN wr.days_to_readmit BETWEEN 8 AND 30 THEN 'Late' ELSE 'None' END AS readmit_category FROM with_readmit AS wr",
      "logic": {
        "sources": [
          {
            "name": "with_readmit",
            "alias": "wr",
            "schema": null,
            "type": "table"
          }
        ],
        "outputs": [
