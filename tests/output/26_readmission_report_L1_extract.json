                "schema": null
              }
            ]
          },
          {
            "name": "is_30day_readmit",
            "expression": "CASE WHEN wr.days_to_readmit <= 30 THEN 1 ELSE 0 END AS is_30day_readmit",
            "type": "case",
            "source_columns": [
              {
                "column": "days_to_readmit",
                "table": "wr",
                "schema": null
              }
            ]
          },
          {
            "name": "readmit_category",
            "expression": "CASE WHEN wr.days_to_readmit <= 7 THEN 'Early' WHEN wr.days_to_readmit BETWEEN 8 AND 30 THEN 'Late' ELSE 'None' END AS readmit_category",
            "type": "case",
