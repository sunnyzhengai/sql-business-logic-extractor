      ]
    },
    {
      "name": "avg_los",
      "type": "aggregate",
      "resolved_expression": "AVG(DATEDIFF(DAY, e.HOSP_ADMSN_TIME, e.HOSP_DISCH_TIME))",
      "direct_expression": "AVG(DATEDIFF(DAY, e.HOSP_ADMSN_TIME, e.HOSP_DISCH_TIME)) AS avg_los",
      "base_columns": [
        "PAT_ENC_HSP.DAY",
        "PAT_ENC_HSP.HOSP_ADMSN_TIME",
        "PAT_ENC_HSP.HOSP_DISCH_TIME"
      ],
      "base_tables": [
        "PAT_ENC_HSP"
      ],
      "filters": [
        "NOT e.HOSP_DISCH_TIME IS NULL"
      ]
    }
  ]
