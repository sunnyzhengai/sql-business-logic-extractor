{
  "columns": [
    {
      "name": "DEPARTMENT_NAME",
      "type": "passthrough",
      "resolved_expression": "CLARITY_DEP.DEPARTMENT_NAME",
      "direct_expression": "dep.DEPARTMENT_NAME",
      "base_columns": [
        "CLARITY_DEP.DEPARTMENT_NAME"
      ],
      "base_tables": [
        "CLARITY_DEP"
      ],
      "filters": [
