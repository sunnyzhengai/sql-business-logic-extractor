      ]
    },
    {
      "name": "encounter_count",
      "type": "aggregate",
      "resolved_expression": "COUNT(DISTINCT e.PAT_ENC_CSN_ID)",
      "direct_expression": "COUNT(DISTINCT e.PAT_ENC_CSN_ID) AS encounter_count",
      "base_columns": [
        "PAT_ENC_HSP.PAT_ENC_CSN_ID"
      ],
      "base_tables": [
        "PAT_ENC_HSP"
      ],
      "filters": [
